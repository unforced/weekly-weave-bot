# Weekly Weave Bot Configuration
# Copy this file to .env and fill in your actual values

# ====================================
# TELEGRAM BOT CONFIGURATION
# ====================================
# Get this from @BotFather on Telegram
# Format: numeric_id:alphanumeric_token
# Example: 7150420449:AAHKZvH3_VBQtR8L9mFH3YX2kNwsXvK-abc
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ====================================
# OPENAI CONFIGURATION
# ====================================
# Get this from https://platform.openai.com/api-keys
# Should start with 'sk-proj-' or 'sk-'
# Example: sk-proj-abcdefghijklmnopqrstuvwxyz123456789
OPENAI_API_KEY=your_openai_api_key_here

# ====================================
# AIRTABLE CONFIGURATION
# ====================================
# Personal Access Token from https://airtable.com/account
# Should start with 'pat' or 'key'
# Example: patABCDEFGHIJKLMNOP.1234567890abcdef
AIRTABLE_API_KEY=your_airtable_api_key_here

# Base ID from your Airtable base (Help > API Documentation)
# Should start with 'app'
# Example: appXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=your_airtable_base_id_here

# ====================================
# ADMIN CONFIGURATION
# ====================================
# Your Telegram user ID (get from @userinfobot)
# For multiple admins, use comma-separated values
# Example: 123456789 or 123456789,987654321
ADMIN_USER_IDS=123456789,987654321

# ====================================
# ENVIRONMENT CONFIGURATION
# ====================================
# Environment mode: development, production, or test
NODE_ENV=development

# Logging level: error, warn, info, debug
LOG_LEVEL=info

# ====================================
# OPTIONAL CONFIGURATION
# ====================================
# Port for health check endpoint (optional)
# PORT=3000

# Request timeout in milliseconds (default: 30000)
# REQUEST_TIMEOUT=30000

# Maximum retries for failed requests (default: 3)
# MAX_RETRIES=3