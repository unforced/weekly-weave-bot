{
  "name": "weekly-weave-bot",
  "version": "1.0.0",
  "description": "Telegram bot for tracking events, updates, and content for Weekly Weave newsletter",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:real": "USE_REAL_AI=1 jest tests/real-ai-extraction.test.ts tests/verified-working.test.ts",
    "test:interactive": "tsx test-scraping-interactive.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "setup:validate": "tsx scripts/setup-validator.ts",
    "diagnose": "tsx scripts/setup-validator.ts"
  },
  "dependencies": {
    "airtable": "^0.12.2",
    "axios": "^1.7.2",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "openai": "^4.65.0",
    "telegraf": "^4.16.3",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.0",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0",
    "chalk": "^5.4.1",
    "eslint": "^9.9.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
